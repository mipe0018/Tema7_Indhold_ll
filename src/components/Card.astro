---
const {img, headline, text} = Astro.props;
---

<article>
 <img src={img} alt="">
 <h3>{headline}</h3>
 <p>{text}</p>
</article>

<style>
    h3 {
        line-height: 2;
font-size: 18px;
}

p {
   font-size: 12px; 
   line-height: 2;
}

img {
    max-width: 100%;
}

article {
    margin: 0 auto;
    padding: 1rem;
}

@media screen and (width >= 768px) {

img {
    max-width: 100%;
    height: 630;
}

h3 {
font-size: 24px;
}

p {
font-size: 18px;
}

}
</style>