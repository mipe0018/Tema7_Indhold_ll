---
const {img, headline, text, direction} = Astro.props;
---

<article class={direction}>
 <img src={img} alt="">
 <div class="content">
 <h3>{headline}</h3>
 <p>{text}</p>
 </div>
</article>

<style>
    h3 {
font-size: 18px;
}

p {
   font-size: 12px; 
}

img {
    max-width: 100%;
    height: 500px;
}

article {
    display: flex;
    flex-direction: column;
    gap: 1em;
}



@media screen and (width >= 768px) {
img {
    max-width: 45%;
    height: 330px;
}

h3 {
font-size: 24px;
}

p {
font-size: 18px;
}

article {
    margin: 0 auto;
    padding: 2rem;
    grid-column: span 2;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    justify-content: space-around;
}

article.left {
    flex-direction: row-reverse;
}

article, h3, p {
    max-width: 85%;
}


}
</style>