---
const {img, headline, text, direction} = Astro.props;
import Button from "../components/Button.astro"
---

<article class={direction}>
 <img src={img} alt="">
 <div class="content">
 <h2>{headline}</h2>
 <p>{text}</p>
 <Button />
 </div>
</article>

<style>
    h2 {
font-size: 18px;
  line-height: 2;
    font-family: montserrat-bold;
}

p {
    margin-bottom: 1.5rem;
   font-size: 12px; 
}

img {
    max-width: 100%;
    height: 500px;
}

article {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}



@media screen and (width >= 768px) {
img {
    max-width: 45%;
    height: 330px;
}

h3 {
font-size: 24px;
}

p {
font-size: 18px;
}

article {
    margin: 0 auto;
    padding: 2rem;
    grid-column: span 2;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    justify-content: space-around;
}

article.right {
    flex-direction: row-reverse;
}

article, h3, p {
    max-width: 85%;
}


}
</style>